<SCRIPT language="javascript">

if(screen.height <= 500)
{
	window.resizeTo (640,450);
	window.moveTo(0,0);
}
else
{
	window.resizeTo (640,480);
	window.moveTo((screen.width-640)/2,(screen.height-480)/2);
}	
</SCRIPT>

